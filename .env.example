# ───────────────────────────────────────────────────────
# Logistics Command Center — environment variables
# Copy this to .env (local) and set in Vercel for prod.
# ───────────────────────────────────────────────────────

# DATABASE
# Local dev: SQLite (default — file in prisma/dev.db)
DATABASE_URL="file:./dev.db"

# Vercel/Production: Postgres connection string from Neon, Vercel Postgres, or Supabase.
# Before deploying, ALSO change `provider = "sqlite"` to `provider = "postgresql"` in prisma/schema.prisma
# Example:  DATABASE_URL="postgresql://user:pass@host.neon.tech/dbname?sslmode=require"

# AUTH (production gate — leave unset locally to skip auth)
# Set a long random string. Visit the dashboard URL and you'll be redirected to /login.
APP_PASSWORD=""

# AI ASSISTANT — enable the chatbot
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# OPTIONAL — Ayrshare unified social-posting (recommended for FB/LinkedIn/IG/TikTok scheduling)
# https://www.ayrshare.com — paste here OR via the /settings/connections UI
AYRSHARE_API_KEY=""

# OPTIONAL — Per-platform tokens (if not using Ayrshare). Set via /settings/connections UI instead.
# LINKEDIN_ACCESS_TOKEN=""
# META_PAGE_TOKEN=""
# IG_BUSINESS_TOKEN=""
