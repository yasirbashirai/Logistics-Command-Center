// Prisma schema — Logistics Command Center
// Covers all 10 dashboard modules + scoring engine.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// -------- App-wide singleton --------
model AppState {
  id              Int      @id @default(1)
  startDate       DateTime
  founderName     String   @default("Yasir Bashir")
  agencyName      String   @default("Logistics Solutions")
  northStarTarget Int      @default(8)
  mrrTarget       Int      @default(10000)
  updatedAt       DateTime @updatedAt
}

// -------- Module 1+2: Plan & Today --------
model Day {
  id             Int          @id @default(autoincrement())
  dayNumber      Int          @unique
  monthNumber    Int          @default(1)
  weekNumber     Int
  weekday        String
  label          String
  focusArea      String
  hoursEstimated Int          @default(4)
  weeklyTheme    String?
  isCustom       Boolean      @default(false)
  tasks          DailyTask[]
}

model Month {
  id             Int      @id @default(autoincrement())
  monthNumber    Int      @unique
  theme          String
  startDayNumber Int
  endDayNumber   Int
  revenueTarget  Int
  mrrTarget      Int
  clientsTarget  Int
  adBudget       Int
  objectives     String
  retainerMix    String?
  notes          String?
}

model DailyTask {
  id             Int       @id @default(autoincrement())
  dayId          Int
  day            Day       @relation(fields: [dayId], references: [id])
  title          String
  description    String?
  category       String
  hoursEstimated Float     @default(1)
  deliverable    String?
  status         String    @default("pending")
  priority       String    @default("normal")
  sortOrder      Int       @default(0)
  pointsValue    Int       @default(10)
  completedAt    DateTime?
  scriptRef      String?
  toolsNeeded    String?
}

model RecurringTask {
  id              Int            @id @default(autoincrement())
  key             String         @unique
  title           String
  category        String
  target          Int
  unit            String
  pointsPerUnit   Float          @default(0.1)
  activeFromDay   Int            @default(8)
  activeToDay     Int            @default(30)
  description     String?
  benchmark       String?
  logs            RecurringLog[]
}

model RecurringLog {
  id              Int           @id @default(autoincrement())
  recurringTaskId Int
  recurringTask   RecurringTask @relation(fields: [recurringTaskId], references: [id])
  date            DateTime
  actualCount     Int
  notes           String?
  createdAt       DateTime      @default(now())

  @@index([date])
}

// -------- Module 3: KPIs --------
model KpiDefinition {
  id              Int      @id @default(autoincrement())
  key             String   @unique
  name            String
  unit            String
  category        String
  weeklyTarget    Float?
  monthlyTarget   Float?
  thresholdMin    Float?
  thresholdHigher Boolean  @default(true)
  isNorthStar     Boolean  @default(false)
  isHealthCheck   Boolean  @default(false)
  description     String?
  failureMode     String?
  logs            KpiLog[]
}

model KpiLog {
  id        Int           @id @default(autoincrement())
  kpiId     Int
  kpi       KpiDefinition @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  date      DateTime
  value     Float
  notes     String?
  createdAt DateTime      @default(now())

  @@index([date])
}

model ScoreSnapshot {
  id             Int      @id @default(autoincrement())
  date           DateTime @unique
  dailyScore     Float
  weeklyScore    Float
  monthlyScore   Float
  streak         Int
  northStarValue Float
  createdAt      DateTime @default(now())
}

// -------- Module 4: Pipeline --------
model Lead {
  id             Int       @id @default(autoincrement())
  name           String
  company        String?
  email          String?
  phone          String?
  source         String
  persona        String?
  stage          String    @default("new")
  estimatedValue Float     @default(0)
  retainerValue  Float     @default(0)
  painPoint      String?
  notes          String?
  tags           String?
  lastActivityAt DateTime  @default(now())
  stageEnteredAt DateTime  @default(now())
  createdAt      DateTime  @default(now())
  closedAt       DateTime?

  @@index([stage])
}

// -------- Module 5: Scripts --------
model Script {
  id             Int     @id @default(autoincrement())
  key            String  @unique
  title          String
  category       String
  persona        String  @default("general")
  funnelStage    String?
  subject        String?
  body           String
  variables      String?
  notes          String?
  dayAppliedFrom Int?
  sortOrder      Int     @default(0)
}

// -------- Module 6: Past Clients --------
model PastClient {
  id                     Int        @id @default(autoincrement())
  name                   String
  company                String?
  email                  String?
  platform               String
  originalProjectYear    Int?
  originalProjectSummary String?
  segment                String     @default("B")
  status                 String     @default("not_contacted")
  loomRecorded           Boolean    @default(false)
  loomUrl                String?
  notes                  String?
  lastContactedAt        DateTime?
  repliedAt              DateTime?
  bookedAt               DateTime?
  closedAt               DateTime?
  createdAt              DateTime   @default(now())
  referrals              Referral[]
}

model Referral {
  id              Int        @id @default(autoincrement())
  pastClientId    Int
  pastClient      PastClient @relation(fields: [pastClientId], references: [id])
  referredName    String
  referredCompany String?
  status          String     @default("pending")
  payoutAmount    Float      @default(500)
  payoutPaid      Boolean    @default(false)
  notes           String?
  createdAt       DateTime   @default(now())
}

// -------- Module 7: Channels --------
model Channel {
  id              Int     @id @default(autoincrement())
  key             String  @unique
  name            String
  priority        String
  status          String  @default("active")
  role            String
  weeklyTarget    Int     @default(0)
  unit            String  @default("count")
  costPerMonth    Float   @default(0)
  expectedClients String?
  benchmarks      String?
  bestPractice    String?
  rules           String?
  notes           String?
  sortOrder       Int     @default(0)
}

// -------- Module 8: Tools --------
model Tool {
  id                   Int       @id @default(autoincrement())
  name                 String    @unique
  role                 String
  category             String
  plan                 String?
  costPerMonth         Float     @default(0)
  status               String    @default("active")
  loginUrl             String?
  alternativesRuledOut String?
  warning              String?
  warningDate          DateTime?
  sortOrder            Int       @default(0)
}

// -------- Module 9: Content Engine --------
model ContentItem {
  id           Int       @id @default(autoincrement())
  type         String
  platform     String    @default("linkedin")
  title        String
  status       String    @default("idea")
  dayOfWeek    String?
  scheduledFor DateTime?
  publishedAt  DateTime?
  hookText     String?
  body         String?
  mediaUrl     String?
  imageUrl     String?
  videoUrl     String?
  postUrl      String?
  notes        String?
  weekNumber   Int?
  monthNumber  Int       @default(1)
  scriptKeyRef String?
  // Engagement (post-publish)
  likes        Int       @default(0)
  comments     Int       @default(0)
  reach        Int       @default(0)
  shares       Int       @default(0)
  inboundDms   Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// -------- Module 11: Paid Ads --------
model AdCampaign {
  id             Int      @id @default(autoincrement())
  name           String
  platform       String
  campaignType   String
  status         String   @default("planned")
  monthNumber    Int      @default(1)
  dailyBudget    Float    @default(0)
  monthlyBudget  Float    @default(0)
  audience       String?
  objective      String?
  startDate      DateTime?
  endDate        DateTime?
  notes          String?
  createdAt      DateTime @default(now())
  creatives      AdCreative[]
  metrics        AdMetric[]
}

model AdCreative {
  id          Int        @id @default(autoincrement())
  campaignId  Int
  campaign    AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name        String
  format      String
  hook        String?
  body        String?
  cta         String?
  scriptKeyRef String?
  mediaUrl    String?
  status      String     @default("draft")
  notes       String?
  createdAt   DateTime   @default(now())
}

model AdMetric {
  id          Int        @id @default(autoincrement())
  campaignId  Int
  campaign    AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  date        DateTime
  spend       Float      @default(0)
  impressions Int        @default(0)
  clicks      Int        @default(0)
  leads       Int        @default(0)
  bookedCalls Int        @default(0)
  notes       String?
  createdAt   DateTime   @default(now())

  @@index([date])
}

// -------- Module 10: Compliance & Brain --------
model Persona {
  id                  Int                @id @default(autoincrement())
  key                 String             @unique
  name                String
  decisionMaker       String
  secondaryInfluencer String?
  topPains            String
  websiteAngle        String
  budgetRange         String
  salesCycle          String
  priorityQuarter     String?
  techLiteracy        String?
  notes               String?
  objections          ObjectionHandler[]
}

model ObjectionHandler {
  id          Int      @id @default(autoincrement())
  objection   String
  realMeaning String
  counter     String
  personaId   Int?
  persona     Persona? @relation(fields: [personaId], references: [id])
  notes       String?
}

model ComplianceRule {
  id        Int    @id @default(autoincrement())
  rule      String
  reason    String
  category  String
  severity  String @default("mandatory")
  source    String?
  sortOrder Int    @default(0)
}

model TimedWarning {
  id            Int      @id @default(autoincrement())
  title         String
  eventDate     DateTime
  type          String
  description   String
  affectedAreas String?
  action        String?
  createdAt     DateTime @default(now())
}

model DecisionRule {
  id           Int    @id @default(autoincrement())
  trigger      String
  action       String
  sourceModule String
  severity     String @default("alert")
  notes        String?
}

// -------- Module 12: Social Connections & Scheduling --------
model SocialAccount {
  id            Int      @id @default(autoincrement())
  platform      String   @unique
  accountName   String?
  accountUrl    String?
  apiKey        String?
  accessToken   String?
  refreshToken  String?
  tokenExpiresAt DateTime?
  connectedAt   DateTime?
  status        String   @default("disconnected")
  scopes        String?
  notes         String?
  updatedAt     DateTime @updatedAt
}

model ScheduledPost {
  id              Int       @id @default(autoincrement())
  contentItemId   Int?
  platform        String
  body            String
  mediaUrl        String?
  scheduledFor    DateTime
  status          String    @default("queued")
  externalPostId  String?
  errorMessage    String?
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
}
